# ──────────────────────────────────────────────────────────────
# AL LAMEA — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans git
# ──────────────────────────────────────────────────────────────

# Web3Forms — https://web3forms.com (gratuit, sans compte requis)
# 1. Aller sur web3forms.com
# 2. Entrer l'email du client (ex: info@allamea.ly)
# 3. Copier la clé générée ci-dessous
VITE_CONTACT_ENDPOINT=https://api.web3forms.com/submit
VITE_CONTACT_ACCESS_KEY=

# URL de production du site
VITE_SITE_URL=https://www.allamea.com

# Google Analytics GA4 (optionnel — si tracking ajouté)
VITE_GA4_ID=
